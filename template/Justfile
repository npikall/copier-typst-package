root := justfile_directory()
export TYPST_ROOT := root

[default]
_default:
    @just --list --unsorted

alias i := install
alias u := uninstall
alias ip := install-preview
alias up := uninstall-preview
alias fmt := format

gotpm := require("gotpm") # get it here: https://github.com/npikall/gotpm
tt := require("tt") # get it here: https://typst-community.github.io/tytanic/quickstart/install.html
typst := require("typst") # get it here: https://github.com/typst/typst#installation
typst-package-check := require("typst-package-check") # get it here: https://github.com/typst/package-check#using-this-tool
typstyle := require("typstyle") # get it here: https://github.com/typst/typstyle
uvx := require("uvx") # get it here: https://docs.astral.sh/uv/getting-started/installation/

# install the pre-commit hooks
[group("dev")]
hooks:
    uvx prek install

# generate manual
[group("typst")]
docs:
    typst compile docs/docs.typ docs/docs.pdf

# generate the thumbnail
[group("typst")]
thumbnail:
    typst compile docs/thumbnail.typ thumbnail.png

# compile the template
[group("typst")]
template:
    typst compile template/main.typ

# format the .typ files
[group("typst")]
format:
    typstyle -i --wrap-text .

# run test suite
[group("test")]
test *args:
    tt run {{ args }}

# update test cases
[group("test")]
update *args:
    tt update {{ args }}

# install the library with the "@local" prefix
[group("package")]
install *args:
    gotpm install {{ args }}

# install the library with the "@preview" prefix (for pre-release testing)
[group("package")]
install-preview:
    gotpm install -n preview

# uninstalls the library from the "@local" prefix
[group("package")]
uninstall *args:
    gotpm uninstall {{ args }}

# uninstalls the library from the "@preview" prefix (for pre-release testing)
[group("package")]
uninstall-preview:
    gotpm uninstall -n preview

# package the library into the specified destination folder
[group("dev")]
dist target:
    GOTPM_INSTALL_DIR="{{ target }}" gotpm install

# run typst package checker
[group("test")]
check:
    just dist dist
    -typst-package-check check dist
    rm -rf dist

# run ci suite (test, doc, thumbnail)
[group("test")]
ci: test docs thumbnail check

# update the package version
[group("dev")]
_bump incr="patch":
    gotpm bump {{ incr }} --indent

_ensure_clean:
    @git diff --quiet
    @git diff --cached --quiet

# write the changelog from commit messages (gh:pawamoy/git-changelog)
[group("dev")]
changelog version=`gotpm bump -c`:
    uvx git-changelog -Tio CHANGELOG.md -B="{{ version }}" -c conventional

_commit_and_tag version=`gotpm bump --show-current`:
    git add .
    git commit -m "chore(release): bumped version to {{ version }}"
    git tag -a "v{{ version }}"

# make a new release [target:<major|minor|patch> or semver]
[group("dev")]
release target: test check
    @just _ensure_clean
    @just _bump {{ target }}
    @just changelog
    @just docs
    @just _commit_and_tag
    @echo "{{ GREEN }}Release complete. Run 'git push && git push --tags'.{{ NORMAL }}"
